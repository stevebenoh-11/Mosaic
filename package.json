{
  "name": "mosaic",
  "private": true,
  "version": "0.1.0",
  "description": "Mosaic visual workspace desktop application",
  "author": "Mosaic Developer",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "electron .",
    "electron:installer": "tsc -b && vite build --base=./ && electron-builder --win",
    "electron:build": "tsc -b && vite build --base=./ && electron-packager . Mosaic --platform=win32 --arch=x64 --out=dist-electron --overwrite --ignore=\"^/(?!dist($|/)|main\\.cjs$|preload\\.cjs$|package\\.json$)\" && powershell -Command \"Compress-Archive -Path dist-electron/Mosaic-win32-x64/* -DestinationPath dist-electron/Mosaic-portable.zip -Force\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "dexie": "^4.0.11",
    "dompurify": "^3.4.9",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-packager": "^17.1.2",
    "fake-indexeddb": "^6.0.0",
    "playwright": "^1.60.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.mosaic.app",
    "productName": "Mosaic",
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
